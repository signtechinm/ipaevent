{
    "devCommand": "npm run dev -- --port $PORT",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api?path=:path"
        },
        {
            "source": "/registration",
            "destination": "/index.html"
        },
        {
            "source": "/sponsor-registration",
            "destination": "/index.html"
        },
        {
            "source": "/admin/login",
            "destination": "/index.html"
        },
        {
            "source": "/admin",
            "destination": "/index.html"
        },
        {
            "source": "/admin/:path*",
            "destination": "/index.html"
        },
        {
            "source": "/scientific-service",
            "destination": "/index.html"
        },
        {
            "source": "/accommodation-travel",
            "destination": "/index.html"
        }
    ]
}
